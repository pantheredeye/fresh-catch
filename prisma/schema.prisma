// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"

  runtime                = "workerd"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"

  output          = "../generated/prisma"
  previewFeatures = ["queryCompiler", "driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(uuid()) // User ID (UUID-based)
  username String  @unique
  email    String? // Email for notifications and account recovery
  name     String? // Full name for orders
  phone    String? // Contact phone

  // Delivery address
  deliveryStreet String?
  deliveryCity   String?
  deliveryState  String?
  deliveryZip    String?
  deliveryNotes  String? // Special instructions

  deletedAt DateTime? // Soft delete timestamp
  createdAt DateTime  @default(now())

  credentials Credential[] // Relationship: One user can have many credentials
  memberships Membership[] // Relationship: User can belong to multiple organizations
  orders      Order[] // Relationship: User can have many orders
  shareEvents ShareEvent[] // Relationship: User can have many share events
}

model Credential {
  id           String   @id @default(uuid()) // Internal DB ID
  userId       String   @unique // Every credential is linked to a specific user
  user         User     @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())
  credentialId String   @unique // WebAuthn credential identifier
  publicKey    Bytes
  counter      Int      @default(0)

  @@index([credentialId])
  @@index([userId])
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique // URL-friendly identifier for business (e.g., 'evan', 'joes-farm')
  type      String // 'individual' or 'business'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Stripe Connect
  stripeAccountId          String?
  stripeOnboardingComplete Boolean @default(false)

  // Fee configuration
  platformFeeBps   Int     @default(500) // Platform fee in basis points (500 = 5%)
  defaultDepositBps Int?                  // Default deposit in basis points (optional)
  feeModel         String  @default("customer") // 'customer' | 'vendor' | 'split'

  memberships Membership[] // Relationship: Organization can have multiple members
  markets     Market[] // Relationship: Organization can have multiple markets
  orders      Order[] // Relationship: Organization can have multiple orders
  shareEvents ShareEvent[] // Relationship: Organization can have multiple share events
}

model Market {
  id              String   @id @default(uuid())
  organizationId  String
  name            String
  schedule        String // Free-form schedule description (e.g., "Sat 8-2")
  subtitle        String? // Optional subtitle (e.g., "Paused until March")
  locationDetails String? // Vendor-facing: booth location, setup notes, parking info
  customerInfo    String? // Customer-facing: payment methods, what to bring, best times
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([active])
}

model Membership {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  role           String // 'owner', 'admin', 'member', etc.
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId]) // Prevent duplicate memberships
  @@index([userId])
  @@index([organizationId])
}

model Order {
  id             String @id @default(uuid())
  orderNumber    Int // Friendly order number (per org, app-managed)
  userId         String
  organizationId String

  // Contact snapshot (captured at order time)
  contactName  String
  contactEmail String?
  contactPhone String?

  // Order details
  items         String // Free-form text describing items
  preferredDate DateTime? // Customer's preferred pickup date
  notes         String? // Customer notes

  // Admin fields
  status     String  @default("pending") // pending | confirmed | completed | cancelled
  price      Int? // Price in cents (replaces old String? format)
  adminNotes String? // Internal notes for Evan

  // Pricing and fees
  tipAmount      Int  @default(0) // Tip in cents
  platformFeeBps Int? // Platform fee in basis points
  platformFee    Int? // Calculated platform fee in cents
  totalDue       Int? // Total amount due in cents
  amountPaid     Int  @default(0) // Amount paid so far in cents
  depositAmount  Int? // Deposit amount in cents

  // Stripe integration
  stripeCheckoutSessionId String? // Stripe Checkout session ID
  stripePaymentIntentId   String? // Stripe PaymentIntent ID

  // Payment tracking
  paymentStatus String    @default("unpaid") // unpaid | paid | refunded
  paymentMethod String? // "cash" | "venmo" | "zelle" | "card" | etc
  paymentNotes  String? // "Venmo: @evan | Paid $45 on 12/29"
  paidAt        DateTime? // When payment was marked as received

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  payments     Payment[]

  @@index([userId])
  @@index([organizationId])
  @@index([status])
  @@index([createdAt])
  @@index([orderNumber])
}

model Payment {
  id              String   @id @default(uuid())
  orderId         String
  amount          Int // Amount in cents
  method          String // stripe | cash | venmo | zelle | other
  type            String // deposit | payment | tip | refund
  stripePaymentId String?
  notes           String?
  createdAt       DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

model ShareEvent {
  id             String   @id @default(uuid())
  organizationId String
  shareType      String // 'link' | 'qr' | 'facebook' | 'twitter' | 'whatsapp'
  sharedBy       String? // User ID (nullable for anonymous/logged-out shares)
  timestamp      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User?        @relation(fields: [sharedBy], references: [id])

  @@index([organizationId])
  @@index([timestamp])
}
