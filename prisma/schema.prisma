// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"

  runtime                = "workerd"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"

  output          = "../generated/prisma"
  previewFeatures = ["queryCompiler", "driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(uuid()) // User ID (UUID-based)
  username String  @unique
  email    String? // Email for notifications and account recovery
  name     String? // Full name for orders
  phone    String? // Contact phone

  // Delivery address
  deliveryStreet String?
  deliveryCity   String?
  deliveryState  String?
  deliveryZip    String?
  deliveryNotes  String? // Special instructions

  passwordHash String? // PBKDF2 hash (hex)
  passwordSalt String? // Salt (hex)

  deletedAt DateTime? // Soft delete timestamp
  createdAt DateTime  @default(now())

  credentials     Credential[] // Relationship: One user can have many credentials
  memberships     Membership[] // Relationship: User can belong to multiple organizations
  orders          Order[] // Relationship: User can have many orders
  shareEvents     ShareEvent[] // Relationship: User can have many share events
  invitesSent     Invite[]     @relation("InvitesSent")
  invitesAccepted Invite[]     @relation("InvitesAccepted")
  conversations   Conversation[] // Conversations where user is a participant
}

model Credential {
  id           String   @id @default(uuid()) // Internal DB ID
  userId       String // Every credential is linked to a specific user (1-to-many: multiple devices per user)
  user         User     @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())
  credentialId String   @unique // WebAuthn credential identifier
  publicKey    Bytes
  counter      Int      @default(0)

  @@index([credentialId])
  @@index([userId])
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique // URL-friendly identifier for business (e.g., 'evan', 'joes-farm')
  type      String // 'individual' or 'business'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Stripe Connect
  stripeAccountId          String?
  stripeOnboardingComplete Boolean @default(false)

  // Fee configuration
  platformFeeBps   Int     @default(500) // Platform fee in basis points (500 = 5%)
  defaultDepositBps Int?                  // Default deposit in basis points (optional)
  feeModel         String  @default("customer") // 'customer' | 'vendor' | 'split'

  memberships   Membership[] // Relationship: Organization can have multiple members
  markets       Market[] // Relationship: Organization can have multiple markets
  orders        Order[] // Relationship: Organization can have multiple orders
  shareEvents   ShareEvent[] // Relationship: Organization can have multiple share events
  invites       Invite[] // Relationship: Organization can have multiple invites
  catchUpdates  CatchUpdate[] // Relationship: Organization can have multiple catch updates
  conversations Conversation[] // Relationship: Organization can have multiple conversations
}

model Market {
  id              String   @id @default(uuid())
  organizationId  String
  name            String
  schedule        String // Free-form schedule description (e.g., "Sat 8-2")
  subtitle        String? // Optional subtitle (e.g., "Paused until March")
  locationDetails String? // Vendor-facing: booth location, setup notes, parking info
  customerInfo    String? // Customer-facing: payment methods, what to bring, best times
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Popup market fields
  type           String    @default("regular") // "regular" | "popup"
  expiresAt      DateTime? // When popup market expires
  catchPreview   String? // JSON: { items: [{name, note}] }
  notes          String? // Catch-all for unstructured voice content
  rawTranscript  String? // Verbatim Whisper output (null for form-created)
  cancelledAt    DateTime? // Set if popup cancelled before happening

  // Location fields
  county         String? // County name, populated by user
  city           String? // City name, populated by user

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([active])
  @@index([organizationId, active])
  @@index([organizationId, type, active])
}

model Membership {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  role           String // 'owner', 'admin', 'member', etc.
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId]) // Prevent duplicate memberships
  @@index([userId])
  @@index([organizationId])
}

/// Order lifecycle state machine:
///
///   pending ──(admin confirms + sets price)──→ confirmed ──→ completed
///     │                                           │
///     └──(customer or admin cancels)──→ cancelled ←┘ (admin cancels)
///
/// Pricing fields populated at each state:
///   pending:   price=null, totalDue=null, amountPaid=0, platformFee=null
///   confirmed: price=set, totalDue=set, platformFee=set, depositAmount=optional
///   completed: same as confirmed; amountPaid may equal totalDue
///   cancelled: fields frozen at time of cancellation
///
/// Payment status (derived via getPaymentStatus in src/utils/payments.ts):
///   null     → totalDue not yet set (pending order)
///   unpaid   → totalDue set, amountPaid=0
///   deposit  → amountPaid > 0 && amountPaid <= depositAmount
///   partial  → amountPaid > depositAmount but < totalDue
///   paid     → amountPaid == totalDue
///   overpaid → amountPaid > totalDue
model Order {
  id             String @id @default(uuid())
  orderNumber    Int // Friendly order number (per org, app-managed)
  userId         String
  organizationId String

  // Contact snapshot (captured at order time)
  contactName  String
  contactEmail String?
  contactPhone String?

  // Order details
  items         String // Free-form text describing items
  preferredDate DateTime? // Customer's preferred pickup date
  notes         String? // Customer notes

  // Admin fields
  status     String  @default("pending") // pending | confirmed | completed | cancelled
  price      Int? // Vendor price in cents, set by admin at confirmation
  adminNotes String? // Internal notes for admin

  // Pricing and fees (all set together at confirmation by confirmOrder)
  tipAmount      Int  @default(0) // Tip in cents, added at checkout
  platformFeeBps Int? // Snapshot of org's fee rate at confirmation
  platformFee    Int? // Calculated platform fee in cents
  totalDue       Int? // Customer-facing total (price + fee, or price - fee, per feeModel)
  amountPaid     Int  @default(0) // Running sum of all Payment records
  depositAmount  Int? // Optional deposit in cents, allows partial-first payment

  // Stripe integration
  stripeCheckoutSessionId String? // Stripe Checkout session ID
  stripePaymentIntentId   String? // Stripe PaymentIntent ID

  // Payment tracking (denormalized from Payment records for quick display)
  paymentMethod String? // Most recent method: "cash" | "venmo" | "zelle" | "card" | etc
  paymentNotes  String? // Most recent payment note
  paidAt        DateTime? // Set when amountPaid >= totalDue

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  payments     Payment[]

  @@index([userId])
  @@index([organizationId])
  @@index([status])
  @@index([createdAt])
  @@unique([organizationId, orderNumber])
}

model Payment {
  id              String   @id @default(uuid())
  orderId         String
  amount          Int // Amount in cents
  method          String // stripe | cash | venmo | zelle | other
  type            String // deposit | payment | tip | refund
  stripePaymentId String?
  notes           String?
  createdAt       DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

model ShareEvent {
  id             String   @id @default(uuid())
  organizationId String
  shareType      String // 'link' | 'qr' | 'facebook' | 'twitter' | 'whatsapp'
  sharedBy       String? // User ID (nullable for anonymous/logged-out shares)
  timestamp      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User?        @relation(fields: [sharedBy], references: [id])

  @@index([organizationId])
  @@index([timestamp])
}

model Invite {
  id             String    @id @default(uuid())
  organizationId String
  email          String?
  role           String // 'owner' or 'manager'
  token          String    @unique
  invitedBy      String
  status         String    @default("pending") // pending | accepted | revoked
  acceptedBy     String?
  createdAt      DateTime  @default(now())
  expiresAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  inviter      User         @relation("InvitesSent", fields: [invitedBy], references: [id])
  acceptor     User?        @relation("InvitesAccepted", fields: [acceptedBy], references: [id])

  @@index([token])
  @@index([organizationId])
}

model CatchUpdate {
  id               String   @id @default(uuid())
  organizationId   String
  recordedBy       String? // Which admin recorded this update
  rawTranscript    String
  formattedContent String // JSON: { headline, items[], summary }
  status           String   @default("live") // "live" or "archived"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([organizationId, status])
}

model Conversation {
  id             String   @id @default(uuid())
  organizationId String
  customerId     String? // Null for anonymous customers
  customerName   String // Display name (provided by customer)
  customerPhone  String? // Optional contact phone
  customerEmail  String? // Optional email for reply notifications
  status         String   @default("open") // "open" | "resolved"
  lastMessageAt  DateTime @default(now()) // For sorting conversations by recency
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  customer     User?        @relation(fields: [customerId], references: [id])
  messages     Message[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, lastMessageAt])
  @@index([customerId])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderType     String // "customer" | "vendor"
  senderId       String? // User ID if authenticated, null for anonymous
  content        String
  readAt         DateTime? // Null until read by recipient
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
  @@index([conversationId, createdAt])
}
